# Telegram bot token from @BotFather (required).
BOT_TOKEN=

# Comma-separated Telegram user ids of admins, e.g. 111111111,222222222
ADMIN_IDS=

# School time zone (IANA name). Used for displaying and parsing times.
TZ=Europe/Minsk

# Default slot duration in minutes.
DEFAULT_SLOT_DURATION_MIN=90

# Path to the SQLite database file (inside the container / volume).
DB_PATH=/data/drivehelper.db
